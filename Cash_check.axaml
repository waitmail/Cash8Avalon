<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="800" d:DesignHeight="600"
        x:Class="Cash8Avalon.Cash_check"
        Title="Чек"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        CanMaximize="False"
        CanMinimize="False"
        SystemDecorations="None"
        SizeToContent="Manual"
        Background="Transparent">
    
    <!-- Внешняя рамка окна -->
    <Border BorderBrush="#FF007ACC" 
            BorderThickness="3"
            Background="White"
            CornerRadius="0">
        
        <Grid>
            <!-- Собственный заголовок окна -->
            <Border Name="CustomTitleBar"
                    Height="40"
                    Background="#FF007ACC"
                    VerticalAlignment="Top"
                    CornerRadius="0,0,0,0">
                
                <Grid>
                    <!-- Название окна -->
                    <TextBlock Text="Чек"
                              x:Name="titleTextBlock" 
                              Foreground="White"
                              FontSize="14"
                              FontWeight="Bold"
                              VerticalAlignment="Center"
                              Margin="15,0,0,0"/>
                </Grid>
            </Border>
            
            <!-- Основной контент (с отступом от заголовка) -->
            <Grid Margin="0,40,0,0">
                
                <!-- Основной контейнер -->
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Верхняя панель с заголовком чека -->
                    <Border Grid.Row="0" Margin="0,0,0,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- Строка 0: Тип чека, Кассир, Email -->
                                    <RowDefinition Height="40"/>
                                    
                                    <!-- Строка 1: Информация об оплате -->
                                    <RowDefinition Height="Auto"/>
                                    
                                    <!-- Строка 2: Последний товар -->
                                    <RowDefinition Height="Auto"/>
                                    
                                    <!-- Строка 3: Клиент, ИНН и Поиск товара -->
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Строка 1: Тип чека и информация + Кассир + Email/телефон -->
                                <Grid Grid.Row="0" Margin="0,0,0,5" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Тип чека:" VerticalAlignment="Center"/>
                                    
                                    <ComboBox Grid.Column="1" Name="check_type" VerticalAlignment="Center" 
                                              VerticalContentAlignment="Center" Width="110" HorizontalAlignment="Left" 
                                              Margin="5,0,0,0"/>

                                    <TextBox Grid.Column="2" Name="txtB_num_sales" IsVisible="False" 
                                             VerticalAlignment="Center" VerticalContentAlignment="Center" 
                                             HorizontalAlignment="Left" Margin="5,0,0,0" Width="120" 
                                             MaxLength="20" HorizontalContentAlignment="Right"
                                             ToolTip.Tip="Введите номер продажи для возврата"/>

                                    <Button Grid.Column="3" Name="btn_fill_on_sales" VerticalAlignment="Center"
                                            VerticalContentAlignment="Center" HorizontalAlignment="Left"
                                            IsVisible="False" Margin="10,0,0,0" MinWidth="150" Height="32" 
                                            Padding="10,5">
                                        Заполнить по продаже
                                    </Button>

                                    <TextBox Grid.Column="4" Name="num_cash" IsReadOnly="True" 
                                             Text="" VerticalAlignment="Center"
                                             VerticalContentAlignment="Center" Margin="10,0"
                                             MinWidth="40" HorizontalAlignment="Left"/>

                                    <TextBox Grid.Column="5" Name="date_time_start" IsReadOnly="True" 
                                             VerticalAlignment="Center" VerticalContentAlignment="Center" 
                                             MinWidth="100" Margin="10,0"/>

                                    <TextBlock Grid.Column="6" Text="Кассир:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="7" Name="user" VerticalAlignment="Center"
                                             IsReadOnly="True" 
                                             VerticalContentAlignment="Center" Margin="5,0"/>

                                    <!-- Email / телефон -->
                                    <TextBlock Grid.Column="8" Text="Email / телефон:" 
                                               VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11"/> 
                                    <TextBox Grid.Column="9" Name="txtB_email_telephone" x:FieldModifier="public"
                                             VerticalAlignment="Center" Margin="5,0"/>
                                </Grid>
                                
                                <!-- Строка 2: Информация об оплате (обернута в Border) -->
                                <Border x:Name="PaymentInfoRow" Grid.Row="1" IsVisible="False" Margin="0,5,0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="Сертификаты:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Name="txtB_sertificate_money" IsEnabled="False"
                                                Margin="5,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="LightGray" BorderThickness="1"
                                                Background="White" Foreground="Black"
                                                Padding="3,2" TextAlignment="Right"
                                                VerticalContentAlignment="Center"/>

                                        <TextBlock Grid.Column="2" Text="Карта:" VerticalAlignment="Center" 
                                                  Margin="10,0,0,0"/>
                                        <TextBox Grid.Column="3" Name="txtB_non_cash_money" IsEnabled="False" 
                                                Margin="5,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="LightGray" BorderThickness="1"
                                                Background="White" Foreground="Black"
                                                Padding="3,2" TextAlignment="Right"
                                                VerticalContentAlignment="Center"/>

                                        <TextBlock Grid.Column="4" Text="Наличные:" VerticalAlignment="Center" 
                                                  Margin="10,0,0,0"/>
                                        <TextBox Grid.Column="5" Name="txtB_cash_money" IsEnabled="False" 
                                                Margin="5,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="LightGray" BorderThickness="1"
                                                Background="White" Foreground="Black"
                                                Padding="3,2" TextAlignment="Right"
                                                VerticalContentAlignment="Center"/>

                                        <TextBlock Grid.Column="6" Text="Бонусы:" VerticalAlignment="Center" 
                                                  Margin="10,0,0,0"/>
                                        <TextBox Grid.Column="7" Name="txtB_bonus_money" IsEnabled="False" 
                                                Margin="5,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="LightGray" BorderThickness="1"
                                                Background="White" Foreground="Black"
                                                Padding="3,2" TextAlignment="Right"
                                                VerticalContentAlignment="Center"/>

                                        <TextBlock Grid.Column="8" Text="№ док:" VerticalAlignment="Center" 
                                                  Margin="10,0,0,0"/>
                                        <TextBox Grid.Column="9" Name="txtB_num_doc" IsEnabled="False" 
                                                Margin="5,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="LightGray" BorderThickness="1"
                                                Background="White" Foreground="Black"
                                                Padding="3,2" TextAlignment="Right"
                                                VerticalContentAlignment="Center"/>

                                        <CheckBox Grid.Column="10" Name="checkBox_payment_by_sbp" Content="СБП" 
                                                 IsEnabled="False" IsVisible="True" VerticalAlignment="Center" 
                                                 Margin="10,0,0,0"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Строка 3: Последний товар -->
                                <TextBox Grid.Row="2" Name="last_tovar" IsReadOnly="True" 
                                         Foreground="Blue" FontSize="26" MinHeight="60" Margin="0,5,0,5"/>
                                
                                <!-- Строка 4: Клиент, ИНН и Поиск товара -->
                                <Grid Grid.Row="3" Margin="0,5,0,5">
                                    <Grid.ColumnDefinitions>
                                        <!-- Клиент: -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Поле клиента -->
                                        <ColumnDefinition Width="150"/>
                                        <!-- ИНН: -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Поле ИНН -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Кнопка "==>" -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Поле наименования -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Код/ШК/Код Марк.: -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Поле поиска товара -->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Клиент -->
                                    <TextBlock Grid.Column="0" Text="Клиент:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Name="client" IsReadOnly="True" 
                                             VerticalAlignment="Center" Margin="10,0"/>
                                    
                                    <!-- ИНН -->
                                    <TextBlock Grid.Column="2" Text="ИНН:" 
                                               IsVisible="False"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <TextBox Grid.Column="3" Name="txtB_inn" MaxLength="12" 
                                             IsVisible="False"
                                             VerticalAlignment="Center" Margin="5,0"/>
                                    
                                    <!-- Кнопка поиска по ИНН -->
                                    <Button Grid.Column="4" Name="btn_get_name" Content="==>" 
                                           IsVisible="False"
                                           VerticalAlignment="Center" Margin="5,0"
                                           Width="40" Height="30"/>
                                    
                                    <!-- Наименование -->
                                    <TextBox Grid.Column="5" Name="txtB_name" MaxLength="250"                                              
                                             IsVisible="False"
                                             VerticalAlignment="Center" Margin="5,0"/>

                                    <!-- Поиск товара -->
                                    <TextBlock Grid.Column="6" Text="Код/ШК/Код Марк.:" 
                                              VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                                    <TextBox Grid.Column="7" Name="txtB_search_product" 
                                            VerticalAlignment="Center" Margin="5,0" FontSize="14"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Основная область: Таблица товаров/сертификатов -->
                    <Border Grid.Row="1" BorderBrush="BlueViolet" BorderThickness="2" Background="White"
                            Margin="0,10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <TabControl x:Name="MainTabControl">
                            <TabItem x:Name="tabProducts" Header="Товары"/>
                            <TabItem x:Name="tabCertificates" Header="Сертификаты"/>                
                        </TabControl>
                    </Border>
                    
                    <!-- Нижняя панель с кнопками -->
                    <Border Grid.Row="2" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Группа "Комментарий:" -->
                                <ColumnDefinition Width="Auto"/>
                                
                                <!-- Чекбоксы вертикально -->
                                <ColumnDefinition Width="Auto"/>
                                
                                <!-- Сумма -->
                                <ColumnDefinition Width="Auto"/>
                                
                                <!-- Пустое пространство между суммой и кнопкой -->
                                <ColumnDefinition Width="*"/>
                                
                                <!-- Кнопка оплаты (прижата вправо) -->
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Группа "Комментарий:" -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" 
                                       VerticalAlignment="Center">
                                <TextBlock Text="Комментарий:" VerticalAlignment="Center"/>
                                <TextBox Name="comment" MaxLength="50" 
                                        VerticalAlignment="Center" Margin="2,0,0,0" 
                                        Width="190"/>
                            </StackPanel>
                            
                            <!-- Чекбоксы вертикально -->
                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <CheckBox Grid.Row="0" Name="checkBox_to_print_repeatedly" 
                                         Content="Напечатать повторно" IsEnabled="False" 
                                         IsVisible="True" Margin="0,0,0,3" FontSize="11"/>
                                
                                <CheckBox Grid.Row="1" Name="checkBox_to_print_repeatedly_p" 
                                         Content="Напечатать маркировку" IsEnabled="False" 
                                         IsVisible="True" Margin="0,0,0,3" FontSize="11"/>
                                
                                <CheckBox Grid.Row="2" Name="checkBox_print_check" 
                                         Content="Печатать чек" FontSize="11" IsVisible="False"/>
                            </Grid>
                            
                            <!-- Сумма -->
                            <TextBox Grid.Column="2" Name="txtB_total_sum" IsReadOnly="True"
                                    FontSize="14" FontWeight="Bold" Foreground="Blue"
                                    MinWidth="120" Margin="0,0,10,0"
                                    VerticalAlignment="Center" TextAlignment="Right"/>
                            
                            <!-- Кнопка оплаты (прижата вправо) -->
                            <Button Grid.Column="4" Name="pay" 
                                   Content="ОПЛАТИТЬ/ВЕРНУТЬ (F8)"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Background="#FF2196F3"
                                   BorderBrush="#1976D2"
                                   BorderThickness="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   HorizontalContentAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Margin="0,0,10,0"
                                   Height="45"
                                   MinWidth="160"
                                   Cursor="Hand"
                                   CornerRadius="5"
                                   Classes="primary">
                                <Button.Styles>
                                    <!-- Основной стиль -->
                                    <Style Selector="Button.primary">
                                        <Setter Property="Background" Value="#FF2196F3"/>
                                        <Setter Property="BorderBrush" Value="#1976D2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
        
                                    <!-- При наведении -->
                                    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#4CAF50"/>
                                    </Style>
        
                                    <!-- При нажатии -->
                                    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Панель ввода количества (скрыта по умолчанию) -->
                    <Border Name="panel1" Background="LightSalmon" IsVisible="False"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Padding="20" Width="400" Height="150" Grid.RowSpan="3">
                         <NumericUpDown Name="numericUpDown_enter_quantity"
                                      Value="0"
                                      Minimum="0"
                                      Maximum="9999"
                                      Increment="0.001"
                                      FormatString="F3"
                                      FontSize="24"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Width="200"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>